{
  "version": 2,
  "buildCommand": "npx prisma generate --schema=backend/prisma/schema.prisma && next build",
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/ws/(.*)",
      "dest": "backend/api/index.ts"
    }
  ]
}
