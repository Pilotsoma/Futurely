NODE_ENV="development"

# PostgreSQL — Neon or any Postgres provider
# SECURITY: sslmode=require is mandatory in production.
# Restrict DB port access to the backend server IP only — never expose it publicly.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host-direct/db?sslmode=require"

# JWT — generate with: node -e "require('crypto').randomBytes(32,(e,b)=>console.log(b.toString('hex')))"
# Must be 64 hex chars (32 bytes). Never use the default in production.
JWT_SECRET="<generate-a-strong-random-secret>"

# Dev auth bypass — set to "true" ONLY for local Expo Go testing, never in production
ENABLE_DEV_INTEGRATION_AUTH_BYPASS="false"

PORT=3001

# SMTP — leave blank to log emails to console (dev mode)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"Futurely" <noreply@futurely.app>'

# Base URL for email links (verification / password reset)
# Use a deep-link scheme for mobile: "futurely://" or your custom scheme
# Use a web URL for web clients: "https://app.futurely.app"
APP_URL="futurely://"
WEB_APP_URL="http://localhost:3000"
# ^ Web-facing redirect base for OAuth completion, email verification, and
#   password-reset links. Distinct from APP_URL, which is the mobile app's
#   futurely:// deep-link scheme — do not conflate the two.

# Comma-separated allowed CORS origins in production (leave blank for mobile-only)
# Example: "https://app.futurely.app,https://admin.futurely.app"
ALLOWED_ORIGINS=""

# Google OAuth credentials (optional — required for social login)
# Get these from Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: [WEB_APP_URL]/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# HAC integration test account
HAC_TEST_DISTRICT_URL="https://homeaccess.katyisd.org/HomeAccess/Account/LogOn"
HAC_TEST_USERNAME=""
HAC_TEST_PASSWORD=""

# AES-256-GCM key for encrypting stored HAC/Canvas credentials
# Generate: node -e "require('crypto').randomBytes(32,(e,b)=>console.log(b.toString('hex')))"
CREDENTIAL_ENCRYPTION_KEY="<64-hex-chars>"

# OpenRouter API key — used for AI chat features (ai.ts, parent.ts)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
