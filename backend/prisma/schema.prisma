datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                Int                  @id @default(autoincrement())
  email             String               @unique
  passwordHash      String
  name              String?
  role              String               @default("STUDENT")
  tag               String?
  tagColor          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  courses           Course[]
  assignments       Assignment[]
  profile           Profile?
  posts             Post[]
  likes             Like[]
  comments          Comment[]
  commentLikes      CommentLike[]
  followers         Follow[]             @relation("Following")
  following         Follow[]             @relation("Follower")
  schoolConnection          SchoolConnection?
  parentLinks               ParentStudentLink[]       @relation("ParentLinks")
  studentLinks              ParentStudentLink[]       @relation("StudentLinks")
  portalConnections         ParentPortalConnection[]  @relation("ParentPortalConnections")
  notificationsReceived     Notification[]       @relation("NotifRecipient")
  notificationsSent         Notification[]       @relation("NotifSender")
  chatBanned                Boolean              @default(false)
  chatMutedUntil            DateTime?
  allTags                   String               @default("[]")
  giveawayEntries           GiveawayEntry[]
  giveawayWins              Post[]               @relation("GiveawayWinner")
}

model Profile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id])
  gradeLevel      Int      @default(9)
  graduationYear  Int?
  weightedGpa     Float    @default(0)
  unweightedGpa   Float    @default(0)
  futureDecision  String?
  satScore        Int?
  actScore        Int?
  counselorName   String?
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  teacher     String
  period      Int
  courseType  String
  creditHours Int
  semester    String
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  grades      Grade[]
}

model Grade {
  id            Int      @id @default(autoincrement())
  letterGrade   String
  percentage    Float
  gradingPeriod String
  courseId      Int
  course        Course   @relation(fields: [courseId], references: [id])
}

model Assignment {
  id               Int       @id @default(autoincrement())
  title            String
  subject          String?
  dueDate          DateTime
  dueTime          String?
  completed        Boolean   @default(false)
  completedAt      DateTime?
  userId           Int
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId, completed])
  @@index([userId, dueDate])
}

model Post {
  id               Int              @id @default(autoincrement())
  body             String
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  likes            Like[]
  comments         Comment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  type             String           @default("post")
  pinnedUntil      DateTime?
  giveawayTag      String?
  giveawayTagColor String?
  giveawayEndsAt   DateTime?
  giveawayWinnerId Int?
  giveawayWinner   User?            @relation("GiveawayWinner", fields: [giveawayWinnerId], references: [id])
  giveawayEntries  GiveawayEntry[]
}

model GiveawayEntry {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  commentLikes CommentLike[] @relation("CommentLikes")
}

model Like {
  id     Int  @id @default(autoincrement())
  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id])
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  user      User     @relation(fields: [userId], references: [id])
  comment   Comment  @relation("CommentLikes", fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Follow {
  id          Int  @id @default(autoincrement())
  followerId  Int
  followingId Int
  follower    User @relation("Follower", fields: [followerId], references: [id])
  following   User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  fromUserId  Int
  type        String   // FOLLOW | LIKE | COMMENT
  postId      Int?
  preview     String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("NotifRecipient", fields: [userId], references: [id])
  sender      User     @relation("NotifSender", fields: [fromUserId], references: [id])
}

model SchoolConnection {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique
  user                  User      @relation(fields: [userId], references: [id])
  systemType            String
  districtUrl           String
  hacUsername           String?
  hacPasswordEncrypted  String?
  psPasswordEncrypted   String?
  cachedSession         String?
  lastSynced            DateTime?
}

model ParentStudentLink {
  id        Int      @id @default(autoincrement())
  parentId  Int
  studentId Int
  createdAt DateTime @default(now())
  parent    User     @relation("ParentLinks", fields: [parentId], references: [id])
  student   User     @relation("StudentLinks", fields: [studentId], references: [id])

  @@unique([parentId, studentId])
}

model ParentPortalConnection {
  id                   Int       @id @default(autoincrement())
  parentId             Int
  parent               User      @relation("ParentPortalConnections", fields: [parentId], references: [id])
  studentName          String?
  gradeLevel           Int?
  graduationYear       Int?
  systemType           String    @default("HAC")
  districtUrl          String
  hacUsername          String
  hacPasswordEncrypted String?
  cachedData           String?
  lastSynced           DateTime?
  createdAt            DateTime  @default(now())

  @@unique([parentId, hacUsername, districtUrl])
}